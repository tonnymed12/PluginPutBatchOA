<mvc:View 
xmlns:mvc="sap.ui.core.mvc" 
xmlns="sap.m" 
xmlns:l="sap.ui.layout" 
xmlns:f="sap.ui.layout.form" 
xmlns:core="sap.ui.core" 
xmlns:ndc="sap.ndc"
xmlns:html="http://www.w3.org/1999/xhtml" 
controllerName="serviacero.custom.plugins.zpluginPutBatchOA.zpluginPutBatchOA.controller.MainView" 
width="100%" 
height="100%">
		
           <Panel
                id="idPluginPanel"
                width="100%"
                height="100%"
                expandable="false"
                expanded="false"
                accessibleRole="Region"
                backgroundDesign="Transparent"
                class="sapUiNoContentPadding">

            <HBox width="80%" class="sapUiSmallMarginBottom">
              <MessageStrip text="{i18n>scannerReady}" type="Information" showIcon="true"
                customIcon="sap-icon://bar-code" class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" />
            </HBox>

            <HBox width="80%" class="sapUiSmallMarginBottom sapUiSmallMarginBeginEnd" alignItems="Center">
                <Label text="{i18n>Barcode}" class="sapUiSmallMarginEnd"/>
                <Input id="scanInput" submit=".onBarcodeSubmit" liveChange=".onScanLiveupdate" class="sapUiSmallMarginEnd sapUiSmallMarginBeginEnd" width="300px"/>
                <ndc:BarcodeScannerButton
                    id="sampleBarcodeScannerButton"
                    scanSuccess="onScanSuccess"
                    scanFail="onScanError"
                    inputLiveUpdate="onScanLiveupdate"
                    dialogTitle="{i18n>BarcodeScanner}"
                    class="sapUiMediumMarginBegin sapUiSmallMarginEnd"
                />
            </HBox>

            <!-- Resumen de orden -->
            <HBox width="80%" class="sapUiTinyMarginBeginEnd sapUiTinyMarginTop" visible="false">
                <Title text="{i18n>orderSummary}" level="H5" class="sapUiSmallMarginBeginEnd"/>
            </HBox>
            <HBox width="80%" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" alignItems="Center" visible="false">
                <VBox width="20%">
                    <Label text="{i18n>loteCode}"/>
                    <Input id="orderLote" value="{orderSummary>/lote}" enabled="false" width="100%"/>
                </VBox>
                <VBox width="20%" class="sapUiSmallMarginBeginEnd">
                    <Label text="{i18n>materialCode}"/>
                    <Input id="orderMaterial" value="{orderSummary>/material}" enabled="false" width="100%"/>
                </VBox>
                <VBox width="30%" class="sapUiSmallMarginEnd">
                    <Label text="{i18n>descripcionMaterial}"/>
                    <Input id="orderDescripcion" value="{orderSummary>/descripcion}" enabled="false" width="100%"/>
                </VBox>
                <VBox width="15%" class="sapUiSmallMarginEnd">
                    <Label text="{i18n>cantidadNecesaria}"/>
                    <Input id="orderCantidadNecesaria" value="{orderSummary>/cantidadNecesaria}" enabled="false" width="100%"/>
                </VBox>
                <VBox width="15%">
                    <Label text="{i18n>cantidadEscaneada}"/>
                    <Input id="orderCantidadEscaneada" value="{orderSummary>/cantidadEscaneada}" enabled="false" width="100%"/>
                </VBox>
            </HBox>
            
            <HBox width="97%" justifyContent="Center" class="sapUiSmallMarginTop sapUiSmallMarginBeginEnd">
            <Table busyIndicatorDelay="5" id="idSlotTable" items="{/ITEMS}"
                class="sapUiSmallMarginTop" width="100%" alternateRowColors="true">
                <headerToolbar>
                    <Toolbar >
                        <Title text="{i18n>Items} ({= ${/ITEMS}.length})" />
                        <ToolbarSpacer />
                        <Button id="refreshBoton" text="{i18n>refresh}" press=".onPressRefresh" 
                        width="100px" class="sapUiSmallMarginBeginEnd" icon="sap-icon://refresh" type="Attention"/>
                        <Button id="clearButton" text="{i18n>clear}" press=".onPressClear" 
                        width="100px" class="sapUiSmallMarginBeginEnd" icon="sap-icon://clear-all" type="Reject"/>
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column width="20%" hAlign="Left" vAlign="Middle" >
                        <Text text="{i18n>materialCode}" />
                    </Column>
                    <Column width="15%" hAlign="Left" vAlign="Middle" >
                        <Text text="{i18n>loteCode}"  />
                    </Column>
                    <Column width="20%" hAlign="Left" vAlign="Middle" >
                        <Text text="{i18n>loteQty}" />
                    </Column>
                    <Column width="10%" hAlign="Center" vAlign="Middle">
                        <Text text="{i18n>ActionModify}" visible="false"/>
                    </Column>
                    <Column width="10%" hAlign="Center" vAlign="Middle">
                        <Text text="{i18n>ActionDelete}" visible="false" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem vAlign="Middle">
                        <cells>
                            <Input value="{Material}" enabled="false" />
                            <Input value="{Batch}" enabled="false" />
                            <Input value="{Quantity}" enabled="true" type="Number" />
                            <Button icon="sap-icon://add" press=".onAddQty"/>
                            <!-- <ndc:BarcodeScannerButton  
                                scanSuccess=".onScanSlotSuccess"
                                scanFail=".onScanError"
                                dialogTitle="{i18n>BarcodeScanner}"
                                visible="false"
                            /> -->
                            <Button icon="sap-icon://delete" press=".onDeleteSlot" type="Reject"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            </HBox>      
    </Panel>
  
</mvc:View>